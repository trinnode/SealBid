    "dotenv": "^16.0.0",
    "ethers": "^6.0.0",
    "hardhat": "2.22.19",
    "hardhat-gas-reporter": "^2.0.0",
    "solhint": "^5.0.0",
    "solidity-coverage": "^0.8.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@fhenixprotocol/contracts": "^0.3.0",
    "@fhenixprotocol/cofhe-contracts": "0.0.13",
